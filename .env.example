# ─────────────────────────────────────────────
#  AI Support App — Environment Variables
# ─────────────────────────────────────────────

# Database — Neon PostgreSQL (or any Postgres provider)
# Pooled connection (used by app at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ai_support_app?sslmode=require"
# Direct connection (used by Prisma for migrations)
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:5432/ai_support_app?sslmode=require"

# Claude AI (Anthropic)
ANTHROPIC_API_KEY="sk-ant-..."
# Optional: override Claude model for conversational turns (default: claude-sonnet-4-6)
# CLAUDE_CONVERSATION_MODEL="claude-sonnet-4-6"
# Optional: override Claude model for fast tasks like summaries (default: claude-haiku-4-5-20251001)
# CLAUDE_FAST_MODEL="claude-haiku-4-5-20251001"

# Twilio — Voice
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+15550001234"

# Sesame CSM — Local TTS (default: http://localhost:8999)
# SESAME_URL="http://localhost:8999"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
PORT=3000
