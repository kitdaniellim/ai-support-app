{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": ".server-build",
    "rootDir": "."
  },
  "include": ["server.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "src/app/**/*.tsx", "src/components/**/*.tsx"]
}
